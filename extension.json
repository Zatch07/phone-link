{
  "extensionId": "phone-link",
  "name": "Phone Link",
  "description": "Seamless phone integration. Click 'Run Dependencies Script' below or visit the GitHub README to setup.",
  "version": "2.5.0",
  "author": "Zatch07",
  "icon": "smartphone",
  "shapeString": "Cookie9Sided",
  "contributes": {
    "sidebarLeftPages": [
      {
        "identifier": "phone",
        "title": "Phone",
        "icon": "smartphone",
        "component": "phone/Phone.qml"
      }
    ],
    "services": [
      { "id": "KdeConnectService", "qml": "services/KdeConnectService.qml" },
      { "id": "PhoneCameraService", "qml": "services/PhoneCameraService.qml" },
      { "id": "PhoneMicService", "qml": "services/PhoneMicService.qml" }
    ]
  },
  "configDefaults": {
    "scrcpy_use_wireless": false,
    "scrcpy_wireless_ip": "",
    "scrcpy_wireless_port": 5555,
    "webcam_connection": "auto",
    "webcam_wifi_ip": "",
    "webcam_port": 4747,
    "webcam_resolution": "1280x720"
  },
  "configSchema": {
    "scrcpy_use_wireless": {
      "type": "boolean",
      "label": "Scrcpy: Use Wireless Debugging",
      "icon": "wifi",
      "default": false
    },
    "scrcpy_wireless_ip": {
      "type": "string",
      "label": "Scrcpy: Wireless IP & Port (e.g. 192.168.1.42:5555)",
      "icon": "router",
      "default": ""
    },
    "scrcpy_wireless_port": {
      "type": "number",
      "label": "Scrcpy: Wireless Port",
      "icon": "tag",
      "default": 5555
    },
    "webcam_connection": {
      "type": "enum",
      "label": "Webcam Connection",
      "icon": "wifi",
      "default": "auto",
      "options": [
        { "displayName": "Auto (Wi-Fi or USB)", "value": "auto" },
        { "displayName": "USB Cable Only", "value": "usb" }
      ]
    },
    "webcam_wifi_ip": {
      "type": "string",
      "label": "DroidCam Wi-Fi IP (Optional) (e.g. 192.168.1.42:4747)",
      "icon": "router",
      "default": ""
    },
    "webcam_port": {
      "type": "number",
      "label": "DroidCam Port",
      "icon": "tag",
      "default": 4747
    },
    "webcam_resolution": {
      "type": "enum",
      "label": "Webcam Resolution",
      "icon": "aspect_ratio",
      "default": "1280x720",
      "options": [
        { "displayName": "480p", "value": "640x480" },
        { "displayName": "720p", "value": "1280x720" },
        { "displayName": "1080p", "value": "1920x1080" }
      ]
    }
  }
}
