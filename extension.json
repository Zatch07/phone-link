{
  "extensionId": "phone-link",
  "name": "Phone Link",
  "description": "Phone integration using KDE Connect, scrcpy, and DroidCam. Use the readme from the github (https://github.com/Zatch07/phone-link) to install dependencies.",
  "version": "1.1.0",
  "author": "Zatch07",
  "icon": "smartphone",
  "shapeString": "Cookie9Sided",
  "contributes": {
    "sidebarLeftPages": [
      {
        "identifier": "phone",
        "title": "Phone",
        "icon": "smartphone",
        "component": "phone/Phone.qml"
      }
    ],
    "services": [
      { "id": "KdeConnectService", "qml": "services/KdeConnectService.qml" },
      { "id": "PhoneCameraService", "qml": "services/PhoneCameraService.qml" },
      { "id": "PhoneMicService", "qml": "services/PhoneMicService.qml" }
    ]
  },
  "configDefaults": {
    "webcam_resolution": "1280x720"
  },
  "configSchema": {
    "webcam_resolution": {
      "type": "enum",
      "label": "Webcam Resolution",
      "icon": "aspect_ratio",
      "default": "1280x720",
      "options": [
        { "displayName": "480p", "value": "640x480" },
        { "displayName": "720p", "value": "1280x720" },
        { "displayName": "1080p", "value": "1920x1080" }
      ]
    },
    "run_setup_script": {
      "type": "string",
      "label": "Command to run Setup Script",
      "icon": "terminal",
      "default": "kitty -- bash -c 'cd ~/.config/illogical-impulse/extensions/installed/phone-link && ./install_dependencies.sh'"
    }
  }
}
